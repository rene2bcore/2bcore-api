# ─── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://2bcore:secret@localhost:5432/2bcore_db

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (RS256) ──────────────────────────────────────────────────────
# Generate with: npm run generate:keys
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=2bcore-api
JWT_AUDIENCE=2bcore-clients

# ─── Security ─────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
API_KEY_PREFIX=sk-live-

# ─── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:4000

# ─── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000

# ─── OpenTelemetry ────────────────────────────────────────────────────
OTEL_SERVICE_NAME=2bcore-api
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_METRICS_PORT=9090

# ─── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info
# LOG_PRETTY=true   # Enable in local dev for human-readable logs
